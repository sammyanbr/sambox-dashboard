{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile containing role and basic info",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": [
            "administrador",
            "gerente",
            "instalador"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected"
          ]
        },
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "email",
        "role",
        "status",
        "createdAt"
      ]
    },
    "Video": {
      "title": "Video Tutorial",
      "description": "Tutorial video with title, description, link and thumbnail",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "thumbnailUrl": {
          "type": "string",
          "format": "uri"
        },
        "createdBy": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "title",
        "url",
        "createdBy",
        "createdAt"
      ]
    },
    "Installation": {
      "title": "Installation Record",
      "description": "Record of a new installation performed by an installer",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telefone": { "type": "string" },
        "instalador": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "email", "telefone", "instalador", "createdBy", "createdAt"]
    },
    "QuickLink": {
      "title": "Quick Sales Link",
      "description": "Quick link for sales",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "valor": { "type": "string" },
        "link": { "type": "string", "format": "uri" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["nome", "valor", "link", "createdBy", "createdAt", "updatedAt", "updatedBy"]
    },
    "CupomItem": {
      "title": "Cupom Item",
      "description": "A standalone coupon item",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "cupons": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "codigo": { "type": "string" },
              "valor": { "type": "string" }
            }
          }
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["nome", "cupons", "createdBy", "createdAt", "updatedAt", "updatedBy"]
    },
    "Noticia": {
      "title": "Notícia/Aviso",
      "description": "News or announcement posted on the mural",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "conteudo": { "type": "string" },
        "author": { "type": "string" },
        "authorId": { "type": "string" },
        "authorPhotoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["titulo", "conteudo", "author", "authorId", "createdAt", "updatedAt", "updatedBy"]
    },
    "AfiliadoOferta": {
      "title": "Afiliado Oferta",
      "description": "Sales offer for affiliates",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "valorCupom": { "type": "string" },
        "cupons": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "codigo": { "type": "string" },
              "valor": { "type": "string" }
            }
          }
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["titulo", "valorCupom", "cupons", "createdBy", "createdAt", "updatedAt", "updatedBy"]
    },
    "DespesaFixa": {
      "title": "Despesa Fixa",
      "description": "Fixed monthly expense",
      "type": "object",
      "properties": {
        "descricao": { "type": "string" },
        "valor": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["descricao", "valor", "createdAt"]
    },
    "Settings": {
      "title": "System Settings",
      "description": "Global system settings",
      "type": "object",
      "properties": {
        "keyAuthSellerKey": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/despesasFixas/{despesaId}": {
      "schema": {
        "$ref": "#/entities/DespesaFixa"
      },
      "description": "Fixed expenses"
    },
    "/settings/{settingId}": {
      "schema": {
        "$ref": "#/entities/Settings"
      },
      "description": "Global settings"
    },
    "/samboxLinks/{linkId}": {
      "schema": {
        "$ref": "#/entities/QuickLink"
      },
      "description": "Quick links for Sambox"
    },
    "/samboxCupons/{cupomId}": {
      "schema": {
        "$ref": "#/entities/CupomItem"
      },
      "description": "Standalone coupons for Sambox"
    },
    "/steamLinks/{linkId}": {
      "schema": {
        "$ref": "#/entities/QuickLink"
      },
      "description": "Quick links for Steam"
    },
    "/steamCupons/{cupomId}": {
      "schema": {
        "$ref": "#/entities/CupomItem"
      },
      "description": "Standalone coupons for Steam"
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User profiles with RBAC roles"
    },
    "/videos/{videoId}": {
      "schema": {
        "$ref": "#/entities/Video"
      },
      "description": "Collection of tutorial videos"
    },
    "/installations/{installationId}": {
      "schema": {
        "$ref": "#/entities/Installation"
      },
      "description": "Records of installations"
    },
    "/noticias/{noticiaId}": {
      "schema": {
        "$ref": "#/entities/Noticia"
      },
      "description": "News mural posts"
    },
    "/afiliadoOfertas/{ofertaId}": {
      "schema": {
        "$ref": "#/entities/AfiliadoOferta"
      },
      "description": "Offers specifically for affiliates"
    }
  }
}
