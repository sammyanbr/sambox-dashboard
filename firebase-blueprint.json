{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile containing role and basic info",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": [
            "administrador",
            "gerente",
            "instalador"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "email",
        "role",
        "createdAt"
      ]
    },
    "Video": {
      "title": "Video Tutorial",
      "description": "Tutorial video with title, description, link and thumbnail",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "thumbnailUrl": {
          "type": "string",
          "format": "uri"
        },
        "createdBy": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "title",
        "url",
        "createdBy",
        "createdAt"
      ]
    },
    "Installation": {
      "title": "Installation Record",
      "description": "Record of a new installation performed by an installer",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telefone": { "type": "string" },
        "instalador": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "email", "telefone", "instalador", "createdBy", "createdAt"]
    },
    "QuickLink": {
      "title": "Quick Sales Link",
      "description": "Quick link for sales with coupons",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "valor": { "type": "string" },
        "link": { "type": "string", "format": "uri" },
        "cupons": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "valor", "link", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "/samboxLinks/{linkId}": {
      "schema": {
        "$ref": "#/entities/QuickLink"
      },
      "description": "Quick links for Sambox"
    },
    "/steamLinks/{linkId}": {
      "schema": {
        "$ref": "#/entities/QuickLink"
      },
      "description": "Quick links for Steam"
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User profiles with RBAC roles"
    },
    "/videos/{videoId}": {
      "schema": {
        "$ref": "#/entities/Video"
      },
      "description": "Collection of tutorial videos"
    },
    "/installations/{installationId}": {
      "schema": {
        "$ref": "#/entities/Installation"
      },
      "description": "Records of installations"
    }
  }
}
