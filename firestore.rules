rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: user uid
    // Fields:
    //   - email: string (required)
    //   - role: string (required, enum: 'administrador', 'gerente', 'instalador')
    //   - displayName: string (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: videos
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - url: string (required)
    //   - description: string (optional)
    //   - thumbnailUrl: string (optional)
    //   - createdBy: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: installations
    // Document ID: auto-generated
    // Fields:
    //   - nome: string (required)
    //   - email: string (required)
    //   - telefone: string (required)
    //   - instalador: string (required)
    //   - createdBy: string (required, email)
    //   - createdAt: timestamp (required)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      let docExists = exists(/databases/$(database)/documents/users/$(request.auth.uid));
      return docExists ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : null;
    }

    function hasRole(role) {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == role;
    }

    function isApproved() {
      let data = getUserData();
      return isAuthenticated() &&
        (
          (data != null && data.status == 'approved') ||
          request.auth.token.email == "sammyanbr@gmail.com" ||
          request.auth.token.email == "zrpg01@gmail.com"
        );
    }

    function isAdmin() {
      let data = getUserData();
      return isAuthenticated() &&
        ((data != null && data.role == 'administrador') ||
         request.auth.token.email == "sammyanbr@gmail.com" ||
         request.auth.token.email == "zrpg01@gmail.com");
    }

    function isInitialAdminCreation() {
      return isAuthenticated() &&
        (request.auth.token.email == "sammyanbr@gmail.com" ||
         request.auth.token.email == "zrpg01@gmail.com");
    }

    function isGerente() {
      return hasRole('gerente') || isAdmin();
    }

    function isValidUser(data) {
      let allowedFields = ['email', 'role', 'status', 'createdAt', 'displayName', 'photoURL'];
      return data.keys().hasOnly(allowedFields) &&
             data.email is string &&
             data.role in ['administrador', 'gerente', 'instalador', 'afiliado'] &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500));
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['title', 'url', 'createdBy', 'createdAt', 'updatedAt', 'updatedBy']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.url is string &&
             data.createdBy is string &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (data.updatedAt is timestamp || data.updatedAt is string) &&
             data.updatedBy is string;
    }

    function isValidInstallation(data) {
      return data.keys().hasAll(['nome', 'email', 'telefone', 'instalador', 'createdBy', 'createdAt', 'updatedAt', 'updatedBy']) &&
             data.nome is string && data.nome.size() > 0 &&
             data.email is string &&
             data.telefone is string &&
             data.instalador is string &&
             data.createdBy is string &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.updatedBy is string;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['date', 'vendas', 'pix', 'ads_facebook', 'ads_google', 'ads_tiktok', 'extras', 'descricao_extra', 'createdBy', 'createdAt', 'updatedAt', 'updatedBy']) &&
             data.date is string &&
             data.vendas is number &&
             data.pix is number &&
             data.ads_facebook is number &&
             data.ads_google is number &&
             data.ads_tiktok is number &&
             data.extras is number &&
             data.descricao_extra is string &&
             data.createdBy is string &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.updatedBy is string;
    }

    function isValidQuickLink(data) {
      return data.keys().hasAll(['nome', 'valor', 'link', 'createdBy', 'createdAt', 'updatedAt', 'updatedBy']) &&
             data.nome is string &&
             data.valor is string &&
             data.link is string &&
             data.createdBy is string &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.updatedBy is string;
    }

    function isValidCupom(data) {
      return data.keys().hasAll(['nome', 'cupons', 'createdBy', 'createdAt', 'updatedAt', 'updatedBy']) &&
             data.nome is string &&
             data.cupons is list &&
             data.createdBy is string &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.updatedBy is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    function isValidNoticia(data) {
      return data.keys().hasAll(['titulo', 'conteudo', 'author', 'authorId', 'createdAt', 'updatedAt', 'updatedBy', 'authorPhotoURL']) &&
             data.titulo is string && data.titulo.size() > 0 &&
             data.conteudo is string && data.conteudo.size() > 0 &&
             data.author is string &&
             data.authorId is string &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.updatedBy is string &&
             data.authorPhotoURL is string;
    }

    match /noticias/{noticiaId} {
      allow read: if isApproved();
      allow create: if isGerente() && isValidNoticia(request.resource.data);
      allow update: if isGerente() && isValidNoticia(request.resource.data);
      allow delete: if isGerente();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isGerente();
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data) &&
                    (request.resource.data.role == 'instalador' || isInitialAdminCreation()) &&
                    (request.resource.data.status == 'pending' || isInitialAdminCreation());
                    
      allow update: if (isOwner(userId) || isAdmin() || isGerente()) && 
                    isValidUser(request.resource.data) &&
                    (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt) &&
                    (!isAdmin() ? request.resource.data.status == resource.data.status : true) &&
                    (!isAdmin() ? (resource.data.role != 'administrador' && request.resource.data.role != 'administrador') : true) &&
                    (!isAdmin() && !isGerente() ? request.resource.data.role == resource.data.role : true);
                    
      allow delete: if isAdmin() || (isGerente() && resource.data.role in ['instalador', 'afiliado']);
    }

    match /videos/{videoId} {
      allow read: if isApproved();
      allow create: if isGerente() && isValidVideo(request.resource.data);
      allow update: if isGerente() && isValidVideo(request.resource.data);
      allow delete: if isGerente();
    }

    match /installations/{installationId} {
      // Instaladores can only read their own installations (filtered by createdBy)
      // Gerentes and Admins can read all.
      // Note: Rules cannot easily filter by string email unless we use queries.
      // The app uses installations.filter(inst => canSeeAll || isOwner)
      // So we must allow list if the query is correctly filtered OR if user is Gerente.
      allow read: if isApproved() && (
        isGerente() || 
        resource.data.createdBy == request.auth.token.email ||
        resource.data.instalador == request.auth.token.email.split('@')[0] ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          resource.data.instalador == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.displayName
        )
      );
      
      allow create: if isApproved() && isValidInstallation(request.resource.data) &&
                    request.resource.data.createdBy == request.auth.token.email;
                    
      allow update: if isGerente() && isValidInstallation(request.resource.data);
      
      allow delete: if isGerente();
    }

    match /transactions/{transactionId} {
      allow read: if isGerente();
      allow create: if isGerente() && isValidTransaction(request.resource.data);
      allow update: if isGerente() && isValidTransaction(request.resource.data);
      allow delete: if isGerente();
    }

    function isValidDespesaFixa(data) {
      return data.keys().hasAll(['descricao', 'valor', 'createdAt', 'updatedAt', 'updatedBy']) &&
             data.descricao is string &&
             data.valor is number &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.updatedBy is string;
    }

    match /despesasFixas/{despesaId} {
      allow read: if isGerente();
      allow create: if isGerente() && isValidDespesaFixa(request.resource.data);
      allow update: if isGerente() && isValidDespesaFixa(request.resource.data);
      allow delete: if isGerente();
    }

    match /settings/{settingId} {
      allow read: if isApproved();
      allow write: if isGerente();
    }

    match /samboxLinks/{linkId} {
      allow read: if isApproved();
      allow create: if isGerente() && isValidQuickLink(request.resource.data);
      allow update: if isGerente() && isValidQuickLink(request.resource.data);
      allow delete: if isGerente();
    }

    match /samboxCupons/{cupomId} {
      allow read: if isApproved();
      allow create: if isGerente() && isValidCupom(request.resource.data);
      allow update: if isGerente() && isValidCupom(request.resource.data);
      allow delete: if isGerente();
    }

    match /steamLinks/{linkId} {
      allow read: if isApproved();
      allow create: if isGerente() && isValidQuickLink(request.resource.data);
      allow update: if isGerente() && isValidQuickLink(request.resource.data);
      allow delete: if isGerente();
    }

    match /steamCupons/{cupomId} {
      allow read: if isApproved();
      allow create: if isGerente() && isValidCupom(request.resource.data);
      allow update: if isGerente() && isValidCupom(request.resource.data);
      allow delete: if isGerente();
    }

    function isValidDenuvoAccount(data) {
      return data.keys().hasAll(['nome', 'email', 'createdAt', 'updatedAt', 'updatedBy', 'createdBy']) &&
             data.nome is string &&
             data.email is string &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.updatedBy is string &&
             data.createdBy is string;
    }

    function isValidDenuvoPrint(data) {
      return data.keys().hasAll(['gameName', 'imageUrl', 'createdAt', 'updatedAt', 'updatedBy', 'createdBy']) &&
             data.gameName is string &&
             data.imageUrl is string &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.updatedBy is string &&
             data.createdBy is string;
    }

    function isValidDenuvoHistory(data) {
      return data.keys().hasAll(['accountId', 'accountName', 'gameName', 'createdByDisplayName', 'createdAt', 'updatedAt', 'updatedBy', 'createdBy']) &&
             data.accountId is string &&
             data.accountName is string &&
             data.gameName is string &&
             data.createdByDisplayName is string &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.updatedBy is string &&
             data.createdBy is string;
    }

    match /denuvoAccounts/{accountId} {
      allow read: if isApproved();
      allow create: if isGerente() && isValidDenuvoAccount(request.resource.data);
      allow update: if isGerente() && isValidDenuvoAccount(request.resource.data);
      allow delete: if isGerente();
    }

    match /denuvoPrints/{printId} {
      allow read: if isApproved();
      allow create: if isGerente() && isValidDenuvoPrint(request.resource.data);
      allow update: if isGerente() && isValidDenuvoPrint(request.resource.data);
      allow delete: if isGerente();
    }

    match /denuvoHistory/{historyId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidDenuvoHistory(request.resource.data);
      allow update: if isApproved() && isValidDenuvoHistory(request.resource.data);
      allow delete: if isGerente();
    }

    match /keyAuthHistory/{historyId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isApproved();
    }
    
    function isValidAfiliadoOferta(data) {
      return data.keys().hasAll(['titulo', 'valorCupom', 'cupons', 'createdBy', 'createdAt', 'updatedAt', 'updatedBy']) &&
             data.titulo is string &&
             data.valorCupom is string &&
             data.cupons is list &&
             data.createdBy is string &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.updatedBy is string;
    }

    match /afiliadoOfertas/{ofertaId} {
      allow read: if isApproved();
      allow create: if isGerente() && isValidAfiliadoOferta(request.resource.data);
      allow update: if isGerente() && isValidAfiliadoOferta(request.resource.data);
      allow delete: if isGerente();
    }

    match /inviteCodes/{codeId} {
      allow read: if true;
      allow create: if isGerente();
      allow update: if isGerente() || isAuthenticated();
      allow delete: if isGerente();
    }
  }
}
